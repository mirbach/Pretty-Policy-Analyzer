{
  "name": "pretty-policy-analyzer",
  "version": "1.0.1",
  "description": "Pretty Policy Analyzer Setup",
  "author": "Pretty Policy Analyzer",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python3.13 -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:electron": "tsc -p electron/tsconfig.json && electron dist-electron/main.js",
    "dev": "concurrently -n fe,be -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "sync:icon": "magick frontend/src/assets/PPALogo.png -background none -alpha on -define icon:auto-resize=256,128,64,48,32,16 electron/icon.ico",
    "build:frontend": "cd frontend && npm run build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:backend": "cd backend && python3.13 -m PyInstaller --noconfirm gpo-backend.spec",
    "build": "npm run sync:icon && npm run build:frontend && npm run build:electron && npm run build:backend",
    "package:win": "npm run build && electron-packager . \"Pretty Policy Analyzer\" --platform=win32 --arch=x64 --icon=electron/icon.ico --out=release --overwrite --extra-resource=backend/dist/gpo-backend --extra-resource=SecurityBaselines",
    "installer:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& npm run build && electron-builder --win nsis --publish never",
    "postinstall": "cd frontend && npm install"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@types/node": "^20.11.0",
    "concurrently": "^9.1.0",
    "electron": "^39.8.8",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.prettypolicyanalyzer.app",
    "productName": "Pretty Policy Analyzer",
    "directories": {
      "output": "release"
    },
    "afterPack": "./electron-builder.afterPack.js",
    "files": [
      "dist-electron/**/*",
      "frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/gpo-backend",
        "to": "gpo-backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "SecurityBaselines",
        "to": "SecurityBaselines",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico",
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "executableName": "Pretty Policy Analyzer"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
