{
  "name": "gpo-analyzer",
  "version": "1.0.0",
  "description": "Analyze, compare, and find conflicts in Active Directory Group Policy backups",
  "author": "Pretty Policy Analyzer",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python3.13 -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:electron": "tsc -p electron/tsconfig.json && electron dist-electron/main.js",
    "dev": "concurrently -n fe,be -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:backend": "cd backend && python3.13 -m PyInstaller --noconfirm gpo-backend.spec",
    "build": "npm run build:frontend && npm run build:electron && npm run build:backend",
    "package:win": "npm run build && electron-packager . \"Pretty Policy Analyzer\" --platform=win32 --arch=x64 --out=release --overwrite --extra-resource=backend/dist/gpo-backend --extra-resource=SecurityBaselines",
    "postinstall": "cd frontend && npm install"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@types/node": "^20.11.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.gpoanalyzer.app",
    "productName": "Pretty Policy Analyzer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/gpo-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "SecurityBaselines",
        "to": "SecurityBaselines",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "forceCodeSigning": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
